{
  "name": "crm-integration",
  "version": "1.0.0",
  "description": "A comprehensive CRM integration system for lead management",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && nodemon index.js",
    "client:dev": "cd client && npm run dev",
    "server:start": "cd server && node index.js",
    "client:build": "cd client && npm run build",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "start": "npm run server:start"
  },
  "keywords": ["crm", "leads", "integration", "customer-management"],
  "author": "CRM Integration Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
} 